# Copy to .env for local dev. Never commit real values.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Notion is READ-ONLY and supplies only the habits/knee log. Share that database
# with the integration (docs/notion_schema.md). The DB ID defaults to the real
# workspace database in config.py; override only if it moves.
# Scheduling context comes from Garmin — there is no tasks DB.
NOTION_TOKEN=
#NOTION_KNEE_LOG_DB_ID=

OPENROUTER_API_KEY=
TAVILY_API_KEY=

DATABASE_URL=postgresql://jim:jim@localhost:5432/jim
APP_TIMEZONE=America/New_York

# Auth is per-user email+password now (sign up at /login) — CHAT_SECRET is gone.
# See SESSION_SECRET and CREDENTIAL_ENCRYPTION_KEY below.

# 32-byte AES-256 key, base64-encoded, for encrypting Garmin/Notion credentials
# at rest (crypto.py). Generate once, e.g. `python -c "import secrets,base64;
# print(base64.b64encode(secrets.token_bytes(32)).decode())"`.
CREDENTIAL_ENCRYPTION_KEY=

# Signing key for session cookies (auth.py). Long random string, separate from
# CREDENTIAL_ENCRYPTION_KEY. Every session becomes invalid if this changes.
SESSION_SECRET=

# --- serverless only (DEPLOY.md) -------------------------------------------
# Gates /api/cron/nightly; Vercel sends it as `Authorization: Bearer $CRON_SECRET`.
# Without it the nightly endpoint is public.
CRON_SECRET=

# Garmin session blob from `python scripts/garmin_login.py --export`. Needed only
# where the ~/.garminconnect token cache is ephemeral and there is no stdin for an
# MFA prompt. Locally, leave blank and use GARMIN_EMAIL/GARMIN_PASSWORD.
GARMIN_TOKENS=
